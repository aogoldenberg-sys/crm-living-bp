rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Вспомогательные функции ────────────────────────────────────────────────

    /**
     * Резолвит businessId пользователя через Firestore users/{uid}.
     * uid ≠ businessId — один тенант может иметь нескольких сотрудников.
     * Для добавления сотрудника: users/{newUid}.businessId = тот же businessId.
     */
    function userBusinessId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    /** Пользователь аутентифицирован и принадлежит тенанту. */
    function belongsTo(businessId) {
      return request.auth != null && userBusinessId() == businessId;
    }

    /**
     * Владелец: role = "owner" в users/{uid}.
     */
    function isOwner(businessId) {
      return belongsTo(businessId)
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner";
    }

    /**
     * Менеджер: role = "manager" в токене.
     * Путь для команды открыт: добавить сотрудника = создать users/{newUid}
     * с тем же businessId и role:"manager", затем выставить custom claim role через workers.
     */
    function isManager(businessId) {
      return belongsTo(businessId)
          && "role" in request.auth.token
          && request.auth.token.role == "manager";
    }

    // ── Тенантные данные ───────────────────────────────────────────────────────

    // Владелец читает всё своего тенанта.
    match /tenants/{businessId}/{document=**} {
      allow read: if isOwner(businessId);
      allow write: if false; // только CF Workers через admin SDK
    }

    // Менеджер читает сделки только с совпадающим ownerId.
    // crmUserId — UUID менеджера в CRM, задаётся auth-воркером в custom claim.
    match /tenants/{businessId}/deals/{dealId} {
      allow read: if isManager(businessId)
                  && "crmUserId" in request.auth.token
                  && resource.data.ownerId == request.auth.token.crmUserId;
    }

    // Менеджер читает конфиг воронки и метрики (нужны для экрана pipeline).
    match /tenants/{businessId}/funnels/{funnelId} {
      allow read: if isManager(businessId);
    }
    match /tenants/{businessId}/funnel_metrics/{funnelId} {
      allow read: if isManager(businessId);
    }

    // users/{uid}: пользователь читает только свой документ; запись — только серверный воркер.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Всё остальное — закрыто.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
